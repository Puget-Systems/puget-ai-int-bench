# Puget Systems AI App Pack — Benchmark Configuration
# Copy this to ~/.config/puget-bench/bench.conf to persist defaults.
#
# All values are optional — command-line flags override config file values.

# Lab cache (DGX Spark): Olah HF mirror (:8090) caches model weights, Squid (:3128)
# caches generic HTTP/Docker. Both are AUTO-DETECTED and used when reachable — you do
# not need to set anything here on the lab network. Deployed via
# puget-hypervisor-devops/terraform (olah_mirror + docker_cache_proxy modules).
#
# Only set CACHE_PROXY to point at a DIFFERENT cache host (the HF mirror is assumed at
# :8090 on the same host). To just change the auto-default host, set the env var
# PUGET_CACHE_HOST=<host> instead.
# CACHE_PROXY=http://OTHER_CACHE_HOST:3128

# Git branch of puget-docker-app-pack to clone (default: main)
# APP_PACK_BRANCH=main

# Default concurrency levels for vLLM benchmarks
# CONCURRENCY=1,4,8,16

# HuggingFace token — required for gated models (Gemma, Llama, etc.)
# Get yours at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sudo password for remote server (teardown/lab machines only)
# SUDO_PASS=[PASSWORD]